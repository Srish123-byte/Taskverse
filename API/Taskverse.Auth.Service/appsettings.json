{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ServiceSettings": {
    "ServiceName": "auth-service",
    "ServiceVersion": "1.0.0",
    "ServicePort": 5001,
    "EnvironmentName": "Development"
  },
  "JwtSettings": {
    "Secret": "your-super-secret-key-change-this-in-production-at-least-32-characters-long",
    "Issuer": "taskverse-api",
    "Audience": "taskverse-clients",
    "ExpiresInMinutes": 60
  },
  "ServiceUrls": {
    "UsersService": "http://localhost:5002",
    "ExamEngine": "http://localhost:5003",
    "AssessmentService": "http://localhost:5006"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4200",
      "https://taskverse.com"
    ]
  }
}
