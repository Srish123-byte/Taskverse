{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "TaskverseDb": "Host=localhost;Port=5432;Database=taskverse_db;Username=postgres;Password=Post@123"
  },
  "ReportsService": {
    "BaseUrl": "https://localhost:5007/",
    "TimeoutSeconds": 30
  },
  "Judge0": {
    "BaseUrl": "https://judge0-ce.p.rapidapi.com/",
    "ApiKey": "YOUR_RAPIDAPI_KEY_PLACEHOLDER",
    "ApiKeyHeaderName": "x-rapidapi-key",
    "ApiHostHeaderName": "x-rapidapi-host",
    "ApiHost": "judge0-ce.p.rapidapi.com",
    "PollDelayMilliseconds": 1000,
    "MaxPollAttempts": 30,
    "TimeoutSeconds": 30
  },
  "CodingEngineWorkers": {
    "Workers": [
      {
        "WorkerId": "worker-dispatch-1",
        "WorkerType": "dispatch",
        "PollingIntervalSeconds": 5,
        "MaxConcurrentExecutions": 3,
        "BatchSize": 5,
        "RateLimitPerMinute": 60
      },
      {
        "WorkerId": "worker-poll-1",
        "WorkerType": "poll",
        "PollingIntervalSeconds": 3,
        "MaxConcurrentExecutions": 5,
        "BatchSize": 10,
        "RateLimitPerMinute": 100
      }
    ]
  },
  "NodeHealthCheck": {
    "IntervalSeconds": 30,
    "TimeoutSeconds": 5,
    "UnhealthyCooldownSeconds": 60
  }
}
